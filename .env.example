# ── x402 payment gate ────────────────────────────────────────────────────────
# OFF by default: the endpoint stays open (free) so the value layer can be
# validated without a wallet. Flip on once you have a receiving address.
X402_ENABLED=false

# Your receiving wallet address (where USDC payments land). Required to enable.
X402_PAY_TO=

# Price per call, in USD of USDC.
X402_PRICE=0.03

# Network: "base-sepolia" (testnet, FREE default facilitator — use this to test)
#       or "base" (mainnet — requires a CDP facilitator: set CDP keys below and
#          wire @coinbase/x402 facilitator into the route).
X402_NETWORK=base-sepolia

# Coinbase CDP facilitator keys (free: https://portal.cdp.coinbase.com).
# Setting BOTH switches the route to the CDP facilitator, which:
#   (a) is REQUIRED for mainnet ("base") settlement, and
#   (b) is what lists the endpoint in the x402 Bazaar / Agentic.Market
#       (the catalog is populated on the first successful settle via CDP).
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

# ── Onchain reads ────────────────────────────────────────────────────────────
# Optional dedicated Base RPC (higher rate limits than the public default).
BASE_RPC_URL=

# Etherscan V2 unified API key (FREE: https://etherscan.io/myapikey — one key works
# for Base, chainid 8453). Enables the DEPLOYER REPUTATION signal: resolves who
# deployed each token and scores their track record (serial-deployer recidivism +
# throwaway-wallet age). Without it, the deployer check is "unknown" (no score
# impact, not counted against confidence). BASESCAN_API_KEY is accepted as an alias.
ETHERSCAN_API_KEY=

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Usage counters via Upstash Redis REST (free tier) or Vercel KV. Without these,
# analytics is a no-op. Create a free DB → copy its REST URL + token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Gate for GET /api/stats — set any secret; view stats at /api/stats?token=<it>.
STATS_TOKEN=
